{
  "name": "scalibity-fundamental-backend",
  "version": "0.0.1",
  "description": "Monorepo NestJS — postgres-app (stateless) + sqlite-app (stateful)",
  "private": true,
  "scripts": {
    "build": "nest build postgres-app && nest build sqlite-app",
    "start:postgres": "nest start postgres-app --watch",
    "start:sqlite": "nest start sqlite-app --watch",
    "start:postgres:prod": "node dist/apps/postgres-app/main.js",
    "start:sqlite:prod": "node dist/apps/sqlite-app/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/typeorm": "^11.0.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.19.17",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
