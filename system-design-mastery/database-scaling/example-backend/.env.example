# PostgreSQL HA (Pgpool) — Helm release postgresql-ha, namespace database
POSTGRES_HOST=postgresql-ha-pgpool.database.svc.cluster.local
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DATABASE=demo_db
# POSTGRES_SSL=true

# Redis Cluster — release redis-cluster
REDIS_CLUSTER_NODES=redis-cluster.database.svc.cluster.local:6379
REDIS_PASSWORD=redis123

# MongoDB Sharded — mongos Service (release mongodb-sharded)
MONGODB_URI=mongodb://root:root123@mongodb-sharded-mongodb-sharded.database.svc.cluster.local:27017/?authSource=admin
MONGODB_DB=demo

# Apache Cassandra — headless để resolve tất cả pod (EN: headless resolves all pods)
CASSANDRA_CONTACT_POINTS=cassandra-headless.database.svc.cluster.local
CASSANDRA_PORT=9042
CASSANDRA_USER=cassandra
CASSANDRA_PASSWORD=cassandra123
CASSANDRA_LOCAL_DC=dc1
# RF=1 cho cluster nhỏ; tăng khi có đủ node (EN: RF=1 for tiny clusters)
CASSANDRA_RF=1

PORT=3000
